# 九洲 RAG 管理平台 - 环境变量配置模板
# 复制此文件为 .env 并填入真实密钥：cp .env.example .env

# ==============================================================================
# 大模型 API Key 配置说明 (双 Key 架构)
#
# 设计背景:
# 1. 基础对话(LLM)和图片解读(Vision)使用按量计费的 Coding Plan API
# 2. Embedding 模型 (打向量) 使用普通的独立 API Key
# ==============================================================================

# DashScope API Key (用于 LLM + Vision) - 对应 Coding Plan API
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# Embedding 专用 API Key - 对应普通 Plan API
EMBEDDING_API_KEY=sk-your-embedding-key-here

# HuggingFace 离线模式 (使用本地缓存，跳过网络检查)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# 知网资料助手 (选填)
MATERIAL_CNKI_USERNAME=""
MATERIAL_CNKI_PASSWORD=""

# Redis 缓存 (选填，不配置则自动使用内存缓存)
# REDIS_URL=redis://localhost:6379/0

# API 认证 (选填，不配置则禁用认证)
# APP_API_KEY=your-api-key-here
