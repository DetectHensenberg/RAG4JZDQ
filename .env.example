# 九洲 RAG 管理平台 - 环境变量配置模板
# 使用说明：
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 将下方占位符替换为你自己的 API Key

# DashScope API Key (用于 LLM + Embedding + Vision)
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# HuggingFace 离线模式 (使用本地缓存模型，跳过网络检查)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Docker 部署端口 (docker-compose 使用)
RAG_PORT=8000
