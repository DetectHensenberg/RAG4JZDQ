# 九洲 RAG 管理平台 - 配置模板
# 使用说明：
#   1. 复制本文件为 settings.yaml:  cp settings.yaml.example settings.yaml
#   2. 按需修改下方配置
#   3. API Key 统一在 .env 文件中配置，此处留空即可

# =============================================================================
# LLM Configuration
# =============================================================================
llm:
  provider: "openai"  # 使用 DashScope 兼容 OpenAI 接口
  model: "qwen3.5-plus"
  base_url: "https://coding.dashscope.aliyuncs.com/v1"
  api_key: ""  # 从环境变量 DASHSCOPE_API_KEY 自动读取
  temperature: 0.0
  max_tokens: 4096
  proxy: ""  # 本地代理，留空则不使用

# =============================================================================
# Embedding Configuration
# =============================================================================
embedding:
  provider: "openai"
  model: "text-embedding-v3"
  dimensions: 1024
  base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  api_key: ""  # 从环境变量 DASHSCOPE_API_KEY 自动读取

# =============================================================================
# Vision LLM Configuration (for Image Captioning)
# =============================================================================
vision_llm:
  enabled: true
  provider: "openai"
  model: "qwen3.5-plus"
  base_url: "https://coding.dashscope.aliyuncs.com/v1"
  api_key: ""  # 从环境变量 DASHSCOPE_API_KEY 自动读取
  max_image_size: 2048
  proxy: ""

# =============================================================================
# Vector Store Configuration
# =============================================================================
vector_store:
  provider: "chroma"
  persist_directory: "./data/db/chroma"
  collection_name: "default"

# =============================================================================
# Retrieval Configuration
# =============================================================================
retrieval:
  dense_top_k: 20
  sparse_top_k: 20
  fusion_top_k: 10
  rrf_k: 60
  query_rewrite: false
  hyde_enabled: false
  parent_retrieval_mode: "auto"
  graph_rag_mode: "auto"
  enable_suggested_questions: true

# =============================================================================
# Rerank Configuration
# =============================================================================
rerank:
  enabled: true
  provider: "cross_encoder"
  model: "BAAI/bge-reranker-base"
  top_k: 5

# =============================================================================
# Evaluation Configuration
# =============================================================================
evaluation:
  enabled: false
  provider: "custom"
  metrics:
    - "hit_rate"
    - "mrr"
    - "faithfulness"

# =============================================================================
# Observability Configuration
# =============================================================================
observability:
  log_level: "INFO"
  trace_enabled: true
  trace_file: "./logs/traces.jsonl"
  structured_logging: true

# =============================================================================
# Ingestion Configuration
# =============================================================================
ingestion:
  chunk_size: 1500
  chunk_overlap: 300
  splitter: "structure"
  batch_size: 100
  pdf_parser: "layout"

  chunk_refiner:
    use_llm: false

  metadata_enricher:
    use_llm: false

  context_enricher:
    enabled: true
